# WordPress REST API Credentials
WP_CRED_URL=https://example.com
WP_CRED_USERNAME=api_user
WP_CRED_PASSWORD=your_application_password_here

# WordPress CLI Settings
WP_CLI_PATH=/path/to/wordpress
WP_CLI_USER=cli_user
WP_CLI_SSH=user@host  # Optional: for remote WP-CLI execution

# Security Settings
WP_SECURE_SALT=random_string_here  # Optional: for additional security measures
WP_API_RATE_LIMIT=100  # Optional: API rate limiting